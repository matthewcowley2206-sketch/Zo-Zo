{
  "redirects": [
    {
      "source": "/prototype-development",
      "destination": "/services/prototype-development",
      "permanent": true
    },
    {
      "source": "/services/sales-marketing",
      "destination": "/services/growth-gtm",
      "permanent": true
    },
    {
      "source": "/services/go-to-market",
      "destination": "/services/growth-gtm",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/services/prototype-development",
      "destination": "/services/prototype-development/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
